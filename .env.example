# ─── Supabase (required) ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── App URL ───
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Mercado Libre ───
MERCADOLIBRE_CLIENT_ID=
MERCADOLIBRE_CLIENT_SECRET=

# ─── OpenAI (optional — AI features) ───
# OPENAI_API_KEY=

# ─── Notes ───
# Supplier credentials (Arnoia, Libral, Azeta) → stored in DB (import_sources table)
# Shopify credentials → stored in DB (shopify_stores table)
# Carrier credentials (Cabify, FastMail) → stored in DB (carriers table)
